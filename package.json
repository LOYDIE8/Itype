{
  "name": "itype",
  "version": "1.0.0",
  "description": "Custom Typing Tutor Desktop App",
  "main": "main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run vite:dev\" \"npm run electron:dev\"",
    "vite:dev": "vite",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "build": "tsc && vite build",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.itype.app",
    "productName": "Itype",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
